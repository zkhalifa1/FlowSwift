# Firebase Configuration
# Get these values from Firebase Console > Project Settings
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id

# Debug Mode
# Set to true to enable logging in production (not recommended)
VITE_DEBUG_MODE=false

# OpenAI API Key Configuration
# IMPORTANT: The frontend does NOT use VITE_OPENAI_API_KEY
# OpenAI API key must be configured in Firebase Cloud Functions:
# firebase functions:config:set openai.key="YOUR_OPENAI_API_KEY"

# Stripe Configuration
# Get your publishable key from Stripe Dashboard > Developers > API keys
# Use test keys (pk_test_...) for development, live keys (pk_live_...) for production
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here

# Stripe Secret Keys (Backend)
# IMPORTANT: The frontend does NOT use STRIPE_SECRET_KEY or STRIPE_WEBHOOK_SECRET
# These must be configured in Firebase Cloud Functions:
# firebase functions:config:set stripe.secret_key="sk_test_YOUR_SECRET_KEY"
# firebase functions:config:set stripe.webhook_secret="whsec_YOUR_WEBHOOK_SECRET"
